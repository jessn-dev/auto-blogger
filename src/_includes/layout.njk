<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Auto Blogger") }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
      --card-bg: rgba(255, 255, 255, 0.05);
      --card-border: rgba(255, 255, 255, 0.1);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --accent: #818cf8;
      --accent-hover: #a5b4fc;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
      background: var(--bg-gradient);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      padding: 2rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--card-border);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .logo {
      font-family: 'Outfit', sans-serif;
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--text-main);
      text-decoration: none;
      background: linear-gradient(to right, #818cf8, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
    }

    main {
      flex: 1;
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 2rem;
      box-sizing: border-box;
    }

    .hero {
      text-align: center;
      margin-bottom: 4rem;
    }

    .hero h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 3.5rem;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.2rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto;
    }

    /* Post Styles */
    article {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 16px;
      padding: 2.5rem;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
      margin-bottom: 2rem;
    }

    article h1, article h2, article h3 {
      font-family: 'Outfit', sans-serif;
      color: var(--accent);
      margin-top: 2rem;
    }

    article h1 {
      font-size: 2.5rem;
      margin-top: 0;
      background: linear-gradient(to right, #a5b4fc, #fbcfe8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    article p {
      line-height: 1.8;
      font-size: 1.1rem;
      margin-bottom: 1.5rem;
    }

    article pre {
      background: #000;
      padding: 1.5rem;
      border-radius: 8px;
      overflow-x: auto;
      border: 1px solid #333;
    }

    article code {
      font-family: monospace;
      background: rgba(255,255,255,0.1);
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      font-size: 0.9em;
    }
    
    article pre code {
      background: none;
      padding: 0;
    }

    .post-meta {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .tag {
      background: rgba(129, 140, 248, 0.2);
      color: #a5b4fc;
      padding: 0.2rem 0.8rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    /* Grid for index page */
    .post-list {
      display: grid;
      gap: 2rem;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .post-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 16px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--text-main);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    .post-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(to right, #818cf8, #c084fc);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .post-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .post-card:hover::before {
      opacity: 1;
    }

    .post-card h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.5rem;
      margin: 0 0 1rem 0;
      line-height: 1.3;
    }

    .post-card .date {
      color: var(--text-muted);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .post-card p {
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
      flex: 1;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
      border-top: 1px solid var(--card-border);
      margin-top: 3rem;
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 2.5rem; }
      article { padding: 1.5rem; }
    }
  </style>
</head>
<body>
  <header>
    <a href="{{ '/' | url }}" class="logo">AutoBlogger AI</a>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>&copy; 2026 AutoBlogger AI. Generated entirely by Artificial Intelligence.</p>
  </footer>
</body>
</html>
